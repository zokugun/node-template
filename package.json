{
	"name": "@zokugun/template",
	"description": "Fast template engine forked from doT with extended and extendable tags & cache plugin",
	"version": "0.1.0",
	"since": "2013-02-28",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/node-template",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/node-template.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/node-template/discussions/categories/issue-triage"
	},
	"type": "module",
	"main": "lib/cjs/index.cjs",
	"module": "lib/esm/index.mjs",
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run build:lib",
		"build:lib": "tsc-leda generate",
		"build:package": "tsc-leda update-package",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib .test .src",
		"compile": "tsc -p src",
		"compile:src": "tsc -p src",
		"compile:test": "tsc -p test",
		"lint": "xo",
		"lint:all": "fixpack && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"prepublishOnly": "npm run compile",
		"release": "release-it",
		"test": "vitest run --reporter tree",
		"test:coverage": "vitest run --reporter tree --coverage --coverage.reporter text",
		"test:ui": "vitest --ui --coverage",
		"test:watch": "vitest",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src",
		"watch:test": "tsc-watch -p test"
	},
	"dependencies": {},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/chai": "^5.0.1",
		"@types/glob": "^8.1.0",
		"@types/node": "22.13.14",
		"@vitest/coverage-v8": "4.1.3",
		"@vitest/ui": "4.1.3",
		"@zokugun/fs-extra-plus": "0.3.6",
		"@zokugun/tsc-leda": "0.3.1",
		"chai": "^5.2.0",
		"eslint-plugin-chai-friendly": "^1.0.1",
		"fixpack": "4.0.0",
		"glob": "^13.0.0",
		"globby": "16.2.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.0.0-1",
		"source-map-support": "^0.5.21",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"vitest": "4.1.3",
		"xo": "0.60.0"
	},
	"keywords": [
		"template",
		"templating",
		"zokugun"
	]
}
